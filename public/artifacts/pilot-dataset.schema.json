{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reading-coach-pilot-dataset.v1",
  "title": "Reading Coach Pilot Dataset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "teacher",
    "teachers",
    "students",
    "classGroups",
    "assignments",
    "sessions",
    "selectedActor",
    "activeAssignmentId",
    "activeSessionId",
    "metadata",
    "exportMetadata"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "teacher": { "$ref": "#/$defs/teacherAccount" },
    "teachers": {
      "type": "array",
      "items": { "$ref": "#/$defs/teacherAccount" }
    },
    "students": {
      "type": "array",
      "items": { "$ref": "#/$defs/studentAccount" }
    },
    "classGroups": {
      "type": "array",
      "items": { "$ref": "#/$defs/classGroup" }
    },
    "assignments": {
      "type": "array",
      "items": { "$ref": "#/$defs/assignment" }
    },
    "sessions": {
      "type": "array",
      "items": { "$ref": "#/$defs/pilotSession" }
    },
    "selectedActor": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/selectedActor" }
      ]
    },
    "activeAssignmentId": { "type": "string", "minLength": 1 },
    "activeSessionId": {
      "anyOf": [
        { "type": "null" },
        { "type": "string", "minLength": 1 }
      ]
    },
    "metadata": { "$ref": "#/$defs/appMetadata" },
    "exportMetadata": { "$ref": "#/$defs/exportMetadata" }
  },
  "$defs": {
    "teacherAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "loginId"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "loginId": { "type": "string", "minLength": 1 }
      }
    },
    "studentAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "displayName", "classGroupId", "studentNumber", "loginId", "participantCode"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "classGroupId": { "type": "string", "minLength": 1 },
        "studentNumber": { "type": "number", "minimum": 1 },
        "loginId": { "type": "string", "minLength": 1 },
        "participantCode": { "type": "string", "pattern": "^[A-Z0-9-]+$" }
      }
    },
    "classGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "teacherId", "studentIds"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "teacherId": { "type": "string", "minLength": 1 },
        "studentIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "selectedActor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "accountId"],
      "properties": {
        "role": { "enum": ["teacher", "student"] },
        "accountId": { "type": "string", "minLength": 1 }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "passage", "question", "gradeLevel", "targetLength"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "passage": { "type": "string", "minLength": 1 },
        "question": { "type": "string", "minLength": 1 },
        "gradeLevel": { "type": "string" },
        "targetLength": { "type": "string" },
        "researchMode": { "type": "string" },
        "researchCondition": { "type": "string" },
        "calibrationConfig": { "$ref": "#/$defs/calibrationConfig" },
        "assignmentMode": { "enum": ["full_process", "revision_feedback"] },
        "essayType": { "type": "string" },
        "minimumWordCount": { "type": "string" },
        "requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sourceGuidance": { "type": "string" },
        "classGroupId": { "type": "string" },
        "createdByTeacherId": { "type": "string" },
        "startDate": { "type": "string" },
        "startTime": { "type": "string" },
        "dueDate": { "type": "string" },
        "dueTime": { "type": "string" }
      }
    },
    "calibrationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topic": { "type": "string" },
        "sourceText": { "type": "string" },
        "aiContext": { "type": "string" },
        "maxChatMinutes": { "type": "number", "minimum": 0 },
        "errorStatement": { "type": "string" },
        "independentTasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "independentProblems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingProblemPrompt" }
        },
        "preSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "predictionSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "reflectionSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "transferChoices": {
          "type": "array",
          "items": { "$ref": "#/$defs/transferChoice" }
        }
      }
    },
    "understandingProblemPrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["number", "title", "prompt"],
      "properties": {
        "number": { "enum": [1, 2, 3, 4] },
        "title": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 }
      }
    },
    "understandingSurveyItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "helper": { "type": "string" }
      }
    },
    "transferChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "text"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "text": { "type": "string" }
      }
    },
    "outline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "evidence", "reasoning", "counterargument", "question"],
      "properties": {
        "claim": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reasoning": { "type": "string" },
        "counterargument": { "type": "string" },
        "question": { "type": "string" }
      }
    },
    "chatTurn": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "text", "timestamp"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "role": { "enum": ["student", "assistant"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string" },
        "responseType": { "$ref": "#/$defs/coachResponseType" }
      }
    },
    "coachResponseType": {
      "enum": ["clarify", "question", "evidence_check", "redirect", "revision_guidance", "refusal"]
    },
    "pilotEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "timestamp", "stage", "payload"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "stage_entered",
            "stage_completed",
            "student_message",
            "assistant_message",
            "outline_edited",
            "claim_revised",
            "evidence_added",
            "counterargument_added",
            "draft_edited",
            "paste_detected",
            "outline_warning_shown",
            "feedback_generated",
            "feedback_viewed",
            "suggestion_checked",
            "suggestion_resolved",
            "submission_created",
            "teacher_review_updated",
            "calibration_pre_survey_submitted",
            "calibration_reading_started",
            "calibration_reading_completed",
            "calibration_chat_started",
            "calibration_chat_turn_created",
            "calibration_chat_completed",
            "calibration_prediction_survey_submitted",
            "calibration_chat_review_submitted",
            "calibration_study_completed",
            "question_started",
            "question_submitted",
            "confidence_submitted",
            "reflection_submitted"
          ]
        },
        "timestamp": { "type": "string" },
        "stage": { "$ref": "#/$defs/stage" },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "draftSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "timestamp", "text"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string" },
        "text": { "type": "string" }
      }
    },
    "pasteEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "timestamp", "stage", "target", "textLength", "lineCount", "textPreviewFirst80", "fromClipboard"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "timestamp": { "type": "string" },
        "stage": { "const": "writing" },
        "target": { "const": "draft" },
        "textLength": { "type": "number", "minimum": 0 },
        "lineCount": { "type": "number", "minimum": 0 },
        "textPreviewFirst80": { "type": "string" },
        "fromClipboard": { "const": true }
      }
    },
    "finalSubmission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "submittedAt"],
      "properties": {
        "text": { "type": "string" },
        "submittedAt": { "type": "string" }
      }
    },
    "teacherReviewNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "note", "updatedAt", "updatedByTeacherId"],
      "properties": {
        "status": { "enum": ["not_reviewed", "needs_follow_up", "reviewed"] },
        "note": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedByTeacherId": {
          "anyOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1 }
          ]
        }
      }
    },
    "pilotSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionId",
        "assignment",
        "researchMode",
        "researchCondition",
        "status",
        "student",
        "currentStage",
        "events",
        "chatTurns",
        "outlineSnapshots",
        "draftSnapshots",
        "pasteEvents",
        "artifacts",
        "measures",
        "modules",
        "finalSubmission",
        "teacherReview",
        "analysisArtifacts",
        "derivedFeatures",
        "manualEvaluation",
        "metadata"
      ],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "assignment": { "$ref": "#/$defs/assignment" },
        "researchMode": { "type": "string" },
        "researchCondition": { "type": "string" },
        "status": { "type": "string" },
        "student": { "$ref": "#/$defs/sessionStudent" },
        "currentStage": { "$ref": "#/$defs/stage" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/pilotEvent" }
        },
        "chatTurns": {
          "type": "array",
          "items": { "$ref": "#/$defs/chatTurn" }
        },
        "outlineSnapshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/outline" }
        },
        "draftSnapshots": {
          "type": "array",
          "items": { "$ref": "#/$defs/draftSnapshot" }
        },
        "pasteEvents": {
          "type": "array",
          "items": { "$ref": "#/$defs/pasteEvent" }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/researchArtifact" }
        },
        "measures": {
          "type": "array",
          "items": { "$ref": "#/$defs/researchMeasure" }
        },
        "modules": { "$ref": "#/$defs/researchModules" },
        "finalSubmission": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/finalSubmission" }
          ]
        },
        "teacherReview": { "$ref": "#/$defs/teacherReviewNote" },
        "analysisArtifacts": { "$ref": "#/$defs/calibrationAnalysisArtifacts" },
        "derivedFeatures": { "$ref": "#/$defs/calibrationDerivedFeatures" },
        "manualEvaluation": { "$ref": "#/$defs/calibrationManualEvaluation" },
        "metadata": { "$ref": "#/$defs/sessionMetadata" },
        "completedAt": { "type": "string" }
      }
    },
    "nullableNumber": {
      "anyOf": [
        { "type": "null" },
        { "type": "number" }
      ]
    },
    "nullableBoolean": {
      "anyOf": [
        { "type": "null" },
        { "type": "boolean" }
      ]
    },
    "nullableScore": {
      "anyOf": [
        { "type": "null" },
        { "enum": [0, 1, 2] }
      ]
    },
    "calibrationAnalysisProblemArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["answer", "answerLength", "problemDurationMs", "promptText", "promptVersion", "questionNumber", "rubricVersion", "submittedAt", "title", "topic"],
      "properties": {
        "answer": { "type": "string" },
        "answerLength": { "type": "number", "minimum": 0 },
        "problemDurationMs": { "$ref": "#/$defs/nullableNumber" },
        "promptText": { "type": "string" },
        "promptVersion": { "type": "string" },
        "questionNumber": { "enum": [1, 2, 3, 4] },
        "rubricVersion": { "type": "string" },
        "submittedAt": { "type": "string" },
        "title": { "type": "string" },
        "topic": { "type": "string" }
      }
    },
    "calibrationAnalysisArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problem1", "problem2", "problem3", "problem4"],
      "properties": {
        "problem1": { "$ref": "#/$defs/calibrationAnalysisProblemArtifact" },
        "problem2": { "$ref": "#/$defs/calibrationAnalysisProblemArtifact" },
        "problem3": { "$ref": "#/$defs/calibrationAnalysisProblemArtifact" },
        "problem4": { "$ref": "#/$defs/calibrationAnalysisProblemArtifact" }
      }
    },
    "calibrationDerivedFeatures": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "absGapOverall",
        "analogyRequestCount",
        "assistantChars",
        "assignmentVersion",
        "calibrationGapOverall",
        "chatTurnCount",
        "confidenceMean",
        "containsWhyQuestion",
        "exampleRequestCount",
        "hasAllFourAnswers",
        "hasAllFourConfidence",
        "hasChat",
        "hasManualScores",
        "isCompleteForAnalysis",
        "itemGaps",
        "offTopicCount",
        "overconfidenceIndex",
        "performanceTotal",
        "predictionMean",
        "preSelfMean",
        "problem1DurationMs",
        "problem2DurationMs",
        "problem3DurationMs",
        "problem4DurationMs",
        "promptVersion",
        "promptSetVersion",
        "questionCount",
        "readingDurationMs",
        "requestTagCounts",
        "rubricVersion",
        "totalChatAssistantChars",
        "totalChatDurationMs",
        "totalChatTurns",
        "totalChatUserChars",
        "totalDurationMs",
        "underconfidenceIndex",
        "userQuestionChars",
        "verificationRequestCount"
      ],
      "properties": {
        "absGapOverall": { "$ref": "#/$defs/nullableNumber" },
        "analogyRequestCount": { "type": "number", "minimum": 0 },
        "assistantChars": { "type": "number", "minimum": 0 },
        "assignmentVersion": { "type": "string" },
        "calibrationGapOverall": { "$ref": "#/$defs/nullableNumber" },
        "chatTurnCount": { "type": "number", "minimum": 0 },
        "confidenceMean": { "$ref": "#/$defs/nullableNumber" },
        "containsWhyQuestion": { "type": "boolean" },
        "exampleRequestCount": { "type": "number", "minimum": 0 },
        "hasAllFourAnswers": { "type": "boolean" },
        "hasAllFourConfidence": { "type": "boolean" },
        "hasChat": { "type": "boolean" },
        "hasManualScores": { "type": "boolean" },
        "isCompleteForAnalysis": { "type": "boolean" },
        "itemGaps": {
          "type": "object",
          "additionalProperties": false,
          "required": ["problem1", "problem2", "problem3", "problem4"],
          "properties": {
            "problem1": { "$ref": "#/$defs/nullableNumber" },
            "problem2": { "$ref": "#/$defs/nullableNumber" },
            "problem3": { "$ref": "#/$defs/nullableNumber" },
            "problem4": { "$ref": "#/$defs/nullableNumber" }
          }
        },
        "offTopicCount": { "type": "number", "minimum": 0 },
        "overconfidenceIndex": { "$ref": "#/$defs/nullableNumber" },
        "performanceTotal": { "$ref": "#/$defs/nullableNumber" },
        "predictionMean": { "$ref": "#/$defs/nullableNumber" },
        "preSelfMean": { "$ref": "#/$defs/nullableNumber" },
        "problem1DurationMs": { "$ref": "#/$defs/nullableNumber" },
        "problem2DurationMs": { "$ref": "#/$defs/nullableNumber" },
        "problem3DurationMs": { "$ref": "#/$defs/nullableNumber" },
        "problem4DurationMs": { "$ref": "#/$defs/nullableNumber" },
        "promptVersion": { "type": "string" },
        "promptSetVersion": { "type": "string" },
        "questionCount": { "type": "number", "minimum": 0 },
        "readingDurationMs": { "$ref": "#/$defs/nullableNumber" },
        "requestTagCounts": {
          "type": "object",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "rubricVersion": { "type": "string" },
        "totalChatAssistantChars": { "type": "number", "minimum": 0 },
        "totalChatDurationMs": { "$ref": "#/$defs/nullableNumber" },
        "totalChatTurns": { "type": "number", "minimum": 0 },
        "totalChatUserChars": { "type": "number", "minimum": 0 },
        "totalDurationMs": { "$ref": "#/$defs/nullableNumber" },
        "underconfidenceIndex": { "$ref": "#/$defs/nullableNumber" },
        "userQuestionChars": { "type": "number", "minimum": 0 },
        "verificationRequestCount": { "type": "number", "minimum": 0 }
      }
    },
    "calibrationManualEvaluationProblem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adjudicatedScore", "codes", "criterionScores", "masteryFlag", "notes", "raterId", "rubricVersion", "scoredAt", "secondRaterId", "totalScore"],
      "properties": {
        "adjudicatedScore": { "$ref": "#/$defs/nullableNumber" },
        "codes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nullableScore" }
        },
        "criterionScores": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applicationJudgment", "conceptAccuracy", "mechanismUnderstanding", "misconceptionCorrection"],
          "properties": {
            "applicationJudgment": { "$ref": "#/$defs/nullableScore" },
            "conceptAccuracy": { "$ref": "#/$defs/nullableScore" },
            "mechanismUnderstanding": { "$ref": "#/$defs/nullableScore" },
            "misconceptionCorrection": { "$ref": "#/$defs/nullableScore" }
          }
        },
        "masteryFlag": { "$ref": "#/$defs/nullableBoolean" },
        "notes": { "type": "string" },
        "raterId": { "type": "string" },
        "rubricVersion": { "type": "string" },
        "scoredAt": { "type": "string" },
        "secondRaterId": { "type": "string" },
        "totalScore": { "$ref": "#/$defs/nullableNumber" }
      }
    },
    "calibrationManualEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notes", "problem1", "problem2", "problem3", "problem4", "raterIds", "rubricVersion", "totalScore"],
      "properties": {
        "notes": { "type": "string" },
        "problem1": { "$ref": "#/$defs/calibrationManualEvaluationProblem" },
        "problem2": { "$ref": "#/$defs/calibrationManualEvaluationProblem" },
        "problem3": { "$ref": "#/$defs/calibrationManualEvaluationProblem" },
        "problem4": { "$ref": "#/$defs/calibrationManualEvaluationProblem" },
        "raterIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rubricVersion": { "type": "string" },
        "totalScore": { "$ref": "#/$defs/nullableNumber" }
      }
    },
    "researchArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["createdAt", "id", "kind", "payload", "stage"],
      "properties": {
        "createdAt": { "type": "string" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "stage": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "researchMeasure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collectedAt", "id", "kind", "payload", "stage"],
      "properties": {
        "collectedAt": { "type": "string" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "payload": {
          "type": "object",
          "additionalProperties": true
        },
        "stage": { "type": "string" }
      }
    },
    "researchModules": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "understandingCalibration": { "$ref": "#/$defs/understandingCalibrationModule" }
      }
    },
    "understandingCalibrationModule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": { "const": "1.0" },
        "topic": { "type": "string" },
        "sourceText": { "type": "string" },
        "aiContext": { "type": "string" },
        "maxChatMinutes": { "type": "number", "minimum": 0 },
        "errorStatement": { "type": "string" },
        "independentTasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "independentProblems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingProblemPrompt" }
        },
        "preSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "predictionSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "reflectionSurveyItems": {
          "type": "array",
          "items": { "$ref": "#/$defs/understandingSurveyItem" }
        },
        "transferChoices": {
          "type": "array",
          "items": { "$ref": "#/$defs/transferChoice" }
        },
        "stageRecords": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/understandingStageRecord" }
        }
      }
    },
    "understandingStageRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage"],
      "properties": {
        "stage": { "type": "string" },
        "submittedAt": { "type": "string" },
        "completedAt": { "type": "string" },
        "eventIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifactIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "measureIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "sessionStudent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anonymousId"],
      "properties": {
        "anonymousId": { "type": "string", "minLength": 1 },
        "accountId": { "type": "string" },
        "displayName": { "type": "string" }
      }
    },
    "appMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appVersion", "createdAt"],
      "properties": {
        "appVersion": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "sessionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["appVersion", "llmMode", "model", "createdAt"],
      "properties": {
        "appVersion": { "type": "string" },
        "llmMode": { "enum": ["mock", "real"] },
        "model": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "fileSyncStatus": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": {
            "status": { "enum": ["pending", "unavailable"] },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "path", "syncedAt"],
          "properties": {
            "status": { "const": "saved" },
            "path": { "type": "string", "minLength": 1 },
            "syncedAt": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "message"],
          "properties": {
            "status": { "const": "failed" },
            "path": { "type": "string" },
            "syncedAt": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      ]
    },
    "exportMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaId", "codebookId", "generatedAt", "fileSync"],
      "properties": {
        "schemaId": { "const": "reading-coach-pilot-dataset.v1" },
        "codebookId": { "const": "critical-thinking-cognitive-offloading-sycophancy.v1" },
        "generatedAt": { "type": "string" },
        "fileSync": { "$ref": "#/$defs/fileSyncStatus" }
      }
    },
    "stage": {
      "enum": [
        "reading",
        "thinking",
        "writing",
        "review",
        "pre_survey",
        "calibration_reading",
        "calibration_chat",
        "prediction_survey",
        "problem_1",
        "problem_1_confidence",
        "problem_2",
        "problem_2_confidence",
        "problem_3",
        "problem_3_confidence",
        "problem_4",
        "problem_4_confidence",
        "reflection_survey",
        "chat_review",
        "final_reflection",
        "completed"
      ]
    }
  }
}
