GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=45000
# Use mock only for automated tests. Leave unset or set real for actual Gemini calls.
# READING_COACH_AI_MODE=mock

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SERVER_AUTH_SECRET=replace-with-a-long-random-server-secret
ADMIN_ID=admin-root
ADMIN_LOGIN_ID=admin
ADMIN_PASSWORD=replace-with-admin-password

# Student research chat and writing coach chat are not hard-blocked by app-level quota.
# This quota remains for non-chat AI helper endpoints.
MAX_AI_REQUESTS_PER_MINUTE=120
MAX_JSON_BODY_BYTES=2000000
EXPORT_SESSION_LIMIT=500

# Optional deployment verification script inputs.
APP_BASE_URL=https://your-vercel-app.vercel.app
VERIFY_TEACHER_LOGIN_ID=teacher
VERIFY_TEACHER_PASSWORD=teacher-password
VERIFY_ADMIN_LOGIN_ID=admin
VERIFY_ADMIN_PASSWORD=replace-with-admin-password
# Comma-separated codes, or auto:30 for S001 through S030.
VERIFY_PARTICIPANT_CODES=S001,S002,S003
# Set to 1 only when you intentionally want the script to spend one AI call per participant.
VERIFY_CHAT=0
